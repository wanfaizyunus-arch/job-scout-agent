# Copy this to .env for local testing (never commit .env to GitHub)
# Set these as Environment Variables on Railway dashboard

# Your Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxx

# Your Gmail address
GMAIL_ADDRESS=wanfaizyunus@gmail.com

# Gmail App Password (NOT your normal Gmail password)
# Get it at: myaccount.google.com/apppasswords
# Enable 2FA first, then create an App Password named "JobAgent"
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Where to send the digest (defaults to GMAIL_ADDRESS if not set)
RECIPIENT_EMAIL=wanfaizyunus@gmail.com
